  },
  "bin": {
    "continuous-improvement": "bin/install.mjs",
    "ci-lint-transcript": "bin/lint-transcript.mjs",
    "ci": "bin/unified-cli.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['bin','test']) { if (!fs.existsSync(dir)) continue; for (const file of fs.readdirSync(dir)) { if (file.endsWith('.mjs')) fs.rmSync(dir + '/' + file, { force: true }); } }\"",
    "test": "npm run build && node --test test/*.test.mjs",
    "lint": "node bin/lint-transcript.mjs --help",
    "verify:generated": "npm run build && git diff --exit-code -- bin test"
  },
  "files": [
    "SKILL.md",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "README.md",
    "llms.txt",
    "action.yml",
    "bin/",
    "hooks/",
    "commands/",
    "skills/",
    "templates/",
    "plugins/",
    "instinct-packs/"
  ],
  "type": "module",
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
